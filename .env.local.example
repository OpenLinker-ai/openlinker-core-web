NEXT_PUBLIC_API_URL=http://localhost:3000
API_URL=http://localhost:8080
CORE_API_URL=http://localhost:8080

# 与后端 ALLOW_LOCAL_HTTP_ENDPOINTS=true 配合，仅用于本地 loopback Agent 调试
NEXT_PUBLIC_ALLOW_LOCAL_HTTP_ENDPOINTS=false

# 生成方法：openssl rand -hex 32（必须与后端 JWT_SECRET 相同）
NEXTAUTH_SECRET=replace-me-with-32-chars-random-secret
NEXTAUTH_URL=http://localhost:3000

# Sentry（可选）
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=
