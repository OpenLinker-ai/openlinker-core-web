NEXT_PUBLIC_API_URL=http://localhost:3000
API_URL=http://localhost:8080
CORE_API_URL=http://localhost:8080

# 与后端 ALLOW_LOCAL_HTTP_ENDPOINTS=true 配合，仅用于本地 loopback Agent 调试
NEXT_PUBLIC_ALLOW_LOCAL_HTTP_ENDPOINTS=false

# 前端会话密钥。生产环境必须使用独立随机值，不要与后端 JWT_SECRET 复用。
# 如果同时设置 AUTH_SECRET 与 NEXTAUTH_SECRET，请保持二者一致。
# 生成方法：openssl rand -hex 32
NEXTAUTH_SECRET=replace-me-with-32-chars-random-secret
NEXTAUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# Sentry（可选）
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=
